{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@firebase/auth": ["./node_modules/@firebase/auth/dist/index.rn.d.ts"],
      // "@firebase/firestore": ["./node_modules/@firebase/firestore/dist/index.rn.d.ts"],
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "src/types/expo-env.d.ts",
    "src/types/nativewind-env.d.ts",
    "nativewind-env.d.ts",
    "expo-env.d.ts"
, "src/lib/firebaseConfig.ts"  ]
}
